// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  DRIVER
}

enum AvailabilityStatus {
  FREE
  LOCKED
}

enum ShiftStatus {
  OPEN
  ASSIGNED
}

enum WhereNeeded {
  DHL
  DRAGONFLY
}

enum ShiftBlockType {
  DHL_OCHTEND
  DHL_MIDDAG
  DHL_AVOND
  DHL_HELEDAG
  DRAGONFLY
}

// Type dienst dat een driver zelf registreert.
enum ShiftType {
  DHL_OCHTEND
  DHL_OCHTEND_MIDDAG
  DHL_AVOND
  DRAGONFLY_MIDDAG
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  availabilities Availability[]
  assignments    Assignment[]
  timeEntries    TimeEntry[]
  driverShifts   DriverShift[]

  @@map("users")
}

model Availability {
  id       String             @id @default(cuid())
  userId   String
  date     String // YYYY-MM-DD
  startHour Int
  endHour   Int
  status   AvailabilityStatus @default(FREE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, date])
  @@map("availabilities")
}

model Shift {
  id        String     @id @default(cuid())
  date      String // YYYY-MM-DD
  blockType ShiftBlockType
  whereNeeded WhereNeeded
  startHour Int
  endHour   Int
  status    ShiftStatus @default(OPEN)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  assignment  Assignment?
  timeEntries TimeEntry[]

  @@index([date, status])
  @@map("shifts")
}

model Assignment {
  id        String   @id @default(cuid())
  shiftId   String   @unique
  userId    String
  createdAt DateTime @default(now())

  // Relations
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@map("assignments")
}

model TimeEntry {
  id         String   @id @default(cuid())
  driverId   String
  driver     User     @relation(fields: [driverId], references: [id])
  shiftId    String?
  shift      Shift?   @relation(fields: [shiftId], references: [id])
  date       DateTime
  startTime  String
  endTime    String
  totalHours Float
  company    String   @default("dragonfly")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([driverId, date])
  @@map("time_entries")
}

// Dienst die een driver zelf registreert: per dag max. één DHL-ochtend
// en/of één Dragonfly-middag. Uren (start/eind) gelden alleen voor Dragonfly,
// pakketten/stops alleen voor DHL. Alles wordt achteraf ingevuld en is optioneel.
model DriverShift {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  type      ShiftType
  startTime String? // "HH:mm" — alleen DRAGONFLY_MIDDAG
  endTime   String? // "HH:mm" — alleen DRAGONFLY_MIDDAG
  packages  Int? // alleen DHL_OCHTEND
  stops     Int? // alleen DHL_OCHTEND
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, date, type])
  @@index([userId, date])
  @@map("driver_shifts")
}
